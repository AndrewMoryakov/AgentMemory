# AgentMemory local environment
# Generated by agentmemory
OPENROUTER_API_KEY=paste-your-openrouter-key-here

# Bearer token required by remote HTTP/MCP clients when exposed publicly.
# Leave blank for a trusted local-only runtime.
# Generate with:  python -c "import secrets; print(secrets.token_urlsafe(32))"
AGENTMEMORY_API_TOKEN=

# Set to 1 on remote deployments to disable the browser UI on / and /ui/*.
AGENTMEMORY_DISABLE_UI=

# OAuth 2.1 for Claude.ai / ChatGPT Custom Connectors.
# Leave blank to disable OAuth (bearer AGENTMEMORY_API_TOKEN still works).
# Generate each with:  python -c "import secrets; print(secrets.token_urlsafe(24))"
AGENTMEMORY_OAUTH_CLIENT_ID=
AGENTMEMORY_OAUTH_CLIENT_SECRET=

# Public-facing base URL used in OAuth discovery payloads.
# Example:  https://andrewm.ru/agentmemory
# Leave blank to derive from X-Forwarded-* headers.
AGENTMEMORY_PUBLIC_URL=
