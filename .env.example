# AgentMemory local environment
# Generated by agentmemory
OPENROUTER_API_KEY=paste-your-openrouter-key-here

# Bearer token required by remote HTTP/MCP clients when exposed publicly.
# Leave blank for a trusted local-only runtime.
# Generate with:  python -c "import secrets; print(secrets.token_urlsafe(32))"
AGENTMEMORY_API_TOKEN=

# Set to 1 on remote deployments to disable the browser UI on / and /ui/*.
AGENTMEMORY_DISABLE_UI=

# Optional static OAuth client for Claude.ai / ChatGPT Custom Connectors.
# Leave blank unless you specifically want a pre-shared client. Modern
# connectors register dynamically via /register (RFC 7591), see below.
# Generate each with:  python -c "import secrets; print(secrets.token_urlsafe(24))"
AGENTMEMORY_OAUTH_CLIENT_ID=
AGENTMEMORY_OAUTH_CLIENT_SECRET=

# Public-facing base URL used in OAuth discovery payloads.
# Example:  https://agentmemorytool.duckdns.org
# Leave blank to derive from X-Forwarded-* headers.
AGENTMEMORY_PUBLIC_URL=

# Set to 1 to disable Dynamic Client Registration (RFC 7591).
# When disabled, /register returns 404 and registration_endpoint vanishes
# from /.well-known/oauth-authorization-server — clients must then be
# pre-shared via AGENTMEMORY_OAUTH_CLIENT_ID/SECRET above.
AGENTMEMORY_OAUTH_DISABLE_DCR=

# Per-IP cap on /register registrations per hour. Defaults to 20.
# Tighten if a single source should not be able to churn the registry.
AGENTMEMORY_REGISTER_RATE_LIMIT_PER_HOUR=

# Override location of the registered-clients JSON store.
# Default: {runtime_dir}/oauth_clients.json
# Used mainly in tests; production should rely on the default so the
# file lands inside the persisted data volume.
AGENTMEMORY_OAUTH_STORE=

# Override location of the OAuth token store (auth codes + access tokens).
# Default: {runtime_dir}/oauth_tokens.json
# Same persistence guarantees as AGENTMEMORY_OAUTH_STORE.
AGENTMEMORY_OAUTH_TOKEN_STORE=
