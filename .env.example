# AgentMemory local environment
# Generated by agentmemory
OPENROUTER_API_KEY=paste-your-openrouter-key-here

# Bearer token required by remote HTTP/MCP clients when exposed publicly.
# Leave blank for a trusted local-only runtime.
# Generate with:  python -c "import secrets; print(secrets.token_urlsafe(32))"
AGENTMEMORY_API_TOKEN=

# Set to 1 on remote deployments to disable the browser UI on / and /ui/*.
AGENTMEMORY_DISABLE_UI=
